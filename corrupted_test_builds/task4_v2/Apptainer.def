Bootstrap: docker

# Use any docker image as a base (see https://hub.docker.com/)
# If using GPU, consider using a CUDA-enabled base image
From: python:3.11-slim

%labels
    Author FOMO26 Challenge - Trigeminal Segmentation Task
    Version v1.0.0
    Description FOMO26 Trigeminal Neuralgia Multiclass Segmentation Apptainer Image

%environment
    export PYTHONUNBUFFERED=1
    export LC_ALL=C.UTF-8

%files
    ./predict.py /app/predict.py
    ./requirements.txt /app/requirements.txt

%post
    mkdir -p /input /output /app

    pip install --no-cache-dir -U pip
    pip install --no-cache-dir -r /app/requirements.txt

    chmod +x /app/predict.py

%runscript
    exec python /app/predict.py "$@"

%help
    This container runs the FOMO26 trigeminal multiclass segmentation task.

    Build this container with:

        `apptainer build --fakeroot /path/to/save/trigeminal.sif /path/to/Apptainer.def`

    Usage:

        `apptainer run --bind /path/to/input:/input:ro \
            --bind /path/to/output:/output \
            --nv \
            trigeminal.sif \
            --t2 /input/t2w.nii.gz \
            --output /output/segmentation.nii.gz`
