Bootstrap: docker

# Use any docker image as a base (see https://hub.docker.com/)
# If using GPU, consider using a CUDA-enabled base image
From: pytorch/pytorch:2.11.0-cuda12.6-cudnn9-runtime

%labels
    Author FOMO26 Challenge - Classification Task
    Version v1.0.0
    Description FOMO26 Infarct Classification Apptainer Image

%environment
    export PYTHONUNBUFFERED=1
    export LC_ALL=C.UTF-8

%files
    ./predict.py /app/predict.py
    ./requirements.txt /app/requirements.txt

%post
    # Create necessary directories
    mkdir -p /input /output /app

    # Install Python dependencies (manylinux wheels available, no compiler needed)
    pip install --no-cache-dir -U pip --break-system-packages
    pip install --no-cache-dir -r /app/requirements.txt --break-system-packages

    # Make predict.py executable
    chmod +x /app/predict.py

%runscript
    # Execute the prediction script with all arguments
    exec python /app/predict.py "$@"

%help
    This container runs the FOMO26 infarct classification task.

    Build this container with:
        
        `apptainer build --fakeroot /path/to/save/classification.sif /path/to/Apptainer.def`

    
    Usage:
        
        `apptainer run --bind /path/to/input:/input:ro \
            --bind /path/to/output:/output \
            --nv \
            classification.sif \
            --flair /input/flair.nii.gz \
            --adc /input/adc.nii.gz \
            --dwi_b1000 /input/dwi.nii.gz \
            --t2s /input/t2s.nii.gz \
            --output /output/sub_id.txt`